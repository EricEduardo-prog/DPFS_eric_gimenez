{
  "name": "app-ee",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node ./bin/www"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "~1.4.4",
    "debug": "~2.6.9",
    "ejs": "^4.0.1",
    "express": "^4.22.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "http-errors": "~1.6.3",
    "method-override": "^3.0.0",
    "morgan": "^1.10.1",
    "session-file-store": "^1.5.0"
  },
  "nodemonConfig": {
    "ignore": [
      "sessions/*",
      "data/*",
      "*.json"
    ],
    "watch": [
      "app.js",
      "routes/",
      "controllers/",
      "models/",
      "views/"
    ],
    "ext": "js,ejs"
  }
}
