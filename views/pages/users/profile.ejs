<%# Vista: pages/users/profile.ejs Controlador: usuarioController.js → verMiPerfil() Variables: - usuario {Object} Datos
    del usuario logueado - mensaje {string|null} Mensaje de éxito (opcional) - error {string|null} Mensaje de error
    (opcional) %>

    <div class="admin-formulario">
        <!-- Encabezado -->
        <div class="admin-formulario__encabezado">
            <div class="admin-formulario__titulo-bloque">
                <h1 class="admin-formulario__titulo">Mi Perfil</h1>
                <span class="admin-formulario__badge admin-formulario__badge--edicion">
                    <%= usuario.is_active ? 'Cuenta activa' : 'Cuenta inactiva' %>
                </span>
            </div>
            <p class="campo-formulario__ayuda">Administrá tus datos personales y de contacto</p>
        </div>

        <!-- Mensajes de feedback -->
        <% if (mensaje) { %>
            <div class="admin-alerta admin-alerta--exito" role="alert">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                    <polyline points="22 4 12 14.01 9 11.01" />
                </svg>
                <%= mensaje %>
            </div>
            <% } %>

                <% if (error) { %>
                    <div class="admin-alerta admin-alerta--error" role="alert">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                        <%= error %>
                    </div>
                    <% } %>

                        <div class="admin-formulario__layout">
                            <!-- COLUMNA PRINCIPAL - Datos personales -->
                            <div class="admin-formulario__columna-principal">

                                <!-- Sección: Información personal -->
                                <div class="admin-formulario__seccion">
                                    <h2 class="admin-formulario__seccion-titulo">
                                        <span class="admin-formulario__seccion-icono">👤</span>
                                        Información personal
                                    </h2>

                                    <div class="admin-detalle__campo">
                                        <div class="admin-detalle__clave">Nombre completo</div>
                                        <div class="admin-detalle__valor">
                                            <strong>
                                                <%= usuario.name %>
                                            </strong>
                                        </div>
                                    </div>

                                    <div class="admin-detalle__campo">
                                        <div class="admin-detalle__clave">Email</div>
                                        <div class="admin-detalle__valor">
                                            <%= usuario.email %>
                                                <span class="admin-detalle__badge">No editable</span>
                                        </div>
                                    </div>

                                    <div class="admin-detalle__campo">
                                        <div class="admin-detalle__clave">Teléfono</div>
                                        <div class="admin-detalle__valor">
                                            <% if (usuario.phone) { %>
                                                <a href="tel:<%= usuario.phone.replace(/\s/g, '') %>"
                                                    class="admin-detalle__link">
                                                    <%= usuario.phone %>
                                                </a>
                                                <% } else { %>
                                                    <span class="admin-detalle__vacio">No especificado</span>
                                                    <% } %>
                                        </div>
                                    </div>
                                </div>

                                <!-- Sección: Dirección -->
                                <div class="admin-formulario__seccion">
                                    <h2 class="admin-formulario__seccion-titulo">
                                        <span class="admin-formulario__seccion-icono">📍</span>
                                        Dirección de envío
                                    </h2>

                                    <% if (usuario.address && (usuario.address.calle || usuario.address.ciudad)) { %>
                                        <div class="admin-detalle__campo">
                                            <div class="admin-detalle__clave">Calle y número</div>
                                            <div class="admin-detalle__valor">
                                                <%= usuario.address.calle || '' %>
                                                    <%= usuario.address.numero || '' %>
                                                        <% if (usuario.address.piso || usuario.address.depto) { %>
                                                            <br><small class="admin-detalle__nota">
                                                                Piso: <%= usuario.address.piso || '-' %>
                                                                    Depto: <%= usuario.address.depto || '-' %>
                                                            </small>
                                                            <% } %>
                                            </div>
                                        </div>
                                        <div class="admin-detalle__campo">
                                            <div class="admin-detalle__clave">Localidad</div>
                                            <div class="admin-detalle__valor">
                                                <%= usuario.address.ciudad || '' %>, <%= usuario.address.provincia || ''
                                                        %>
                                            </div>
                                        </div>
                                        <div class="admin-detalle__campo">
                                            <div class="admin-detalle__clave">Código postal</div>
                                            <div class="admin-detalle__valor">
                                                <%= usuario.address.codigoPostal || 'No especificado' %>
                                            </div>
                                        </div>
                                        <% } else { %>
                                            <div class="admin-detalle__vacio-contenedor">
                                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="1.5">
                                                    <path
                                                        d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" />
                                                    <circle cx="12" cy="9" r="2.5" />
                                                </svg>
                                                <p>No has agregado una dirección de envío</p>
                                            </div>
                                            <% } %>
                                </div>

                                <!-- Sección: Historial de actividad -->
                                <div class="admin-formulario__seccion">
                                    <h2 class="admin-formulario__seccion-titulo">
                                        <span class="admin-formulario__seccion-icono">📊</span>
                                        Actividad de la cuenta
                                    </h2>

                                    <div class="admin-detalle__campo">
                                        <div class="admin-detalle__clave">Fecha de registro</div>
                                        <div class="admin-detalle__valor">
                                            <%= new Date(usuario.created_at).toLocaleDateString('es-AR', {
                                                day: 'numeric' , month: 'long' , year: 'numeric' , hour: '2-digit' ,
                                                minute: '2-digit' }) %>
                                        </div>
                                    </div>

                                    <% if (usuario.updated_at && usuario.updated_at !==usuario.created_at) { %>
                                        <div class="admin-detalle__campo">
                                            <div class="admin-detalle__clave">Última modificación</div>
                                            <div class="admin-detalle__valor">
                                                <%= new Date(usuario.updated_at).toLocaleDateString('es-AR', {
                                                    day: 'numeric' , month: 'long' , year: 'numeric' , hour: '2-digit' ,
                                                    minute: '2-digit' }) %>
                                            </div>
                                        </div>
                                        <% } %>
                                </div>
                            </div>

                            <!-- COLUMNA LATERAL -->
                            <aside class="admin-formulario__lateral">

                                <!-- Card: Avatar y acciones rápidas -->
                                <div class="admin-lateral__card">
                                    <div class="profile-avatar">
                                        <div class="profile-avatar__circle">
                                            <%= usuario.name.charAt(0).toUpperCase() %>
                                        </div>
                                        <h3 class="profile-avatar__name">
                                            <%= usuario.name %>
                                        </h3>
                                        <p class="profile-avatar__email">
                                            <%= usuario.email %>
                                        </p>
                                    </div>

                                    <div class="profile-actions">
                                        <a href="/usuarios/perfil/editar" class="boton boton--primario"
                                            style="width: 100%;">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                            </svg>
                                            Editar perfil
                                        </a>
                                        <a href="/usuarios/cambiar-password" class="boton boton--secundario"
                                            style="width: 100%; margin-top: var(--espacio-sm);">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                                            </svg>
                                            Cambiar contraseña
                                        </a>
                                    </div>
                                </div>

                                <!-- Card: Estado de la cuenta -->
                                <div class="admin-lateral__card">
                                    <h3 class="admin-lateral__card-titulo">Estado de la cuenta</h3>
                                    <div class="estado-indicator">
                                        <span
                                            class="estado-indicator__dot estado-indicator__dot--<%= usuario.is_active ? 'activo' : 'inactivo' %>"></span>
                                        <span class="estado-indicator__texto">
                                            <%= usuario.is_active ? 'Cuenta activa' : 'Cuenta inactiva' %>
                                        </span>
                                    </div>
                                    <p class="campo-formulario__ayuda" style="margin-top: var(--espacio-sm);">
                                        <%= usuario.is_active ? 'Tu cuenta está activa y puedes realizar compras.'
                                            : 'Tu cuenta está desactivada. Contacta al administrador.' %>
                                    </p>
                                </div>

                                <!-- Card: Información de la sesión -->
                                <div class="admin-lateral__card admin-lateral__card--metadata">
                                    <h3 class="admin-lateral__card-titulo">Sesión actual</h3>
                                    <ul class="metadata-lista">
                                        <li class="metadata-item">
                                            <span class="metadata-item__clave">ID de usuario</span>
                                            <span class="metadata-item__valor metadata-item__valor--codigo">
                                                <%= usuario.id %>
                                            </span>
                                        </li>
                                        <li class="metadata-item">
                                            <span class="metadata-item__clave">Autenticado</span>
                                            <span class="metadata-item__valor">✓ Sí</span>
                                        </li>
                                    </ul>
                                    <form action="/logout" method="POST" style="display: inline; width: 100%;">
                                        <button type="submit" class="boton boton--secundario"
                                            style="width: 100%; margin-top: var(--espacio-md);">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                                                <polyline points="16 17 21 12 16 7" />
                                                <line x1="21" y1="12" x2="9" y2="12" />
                                            </svg>
                                            Cerrar sesión
                                        </button>
                                    </form>
                                </div>

                                <!-- Card: Links rápidos -->
                                <div class="admin-lateral__card">
                                    <h3 class="admin-lateral__card-titulo">Enlaces útiles</h3>
                                    <ul class="metadata-lista">
                                        <li class="metadata-item">
                                            <a href="/usuarios/pedidos" class="admin-detalle__link">📦 Mis pedidos</a>
                                        </li>
                                        <li class="metadata-item">
                                            <a href="/" class="admin-detalle__link">🏠 Ir al inicio</a>
                                        </li>
                                        <li class="metadata-item">
                                            <a href="/productos" class="admin-detalle__link">🛒 Seguir comprando</a>
                                        </li>
                                    </ul>
                                </div>
                            </aside>
                        </div>
    </div>