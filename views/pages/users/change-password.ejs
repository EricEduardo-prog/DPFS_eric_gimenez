<%# Vista: pages/users/change-password.ejs Controlador: usuarioController.js → formCambiarPassword() /
    actualizarPassword() Variables: - errores {Array} Mensajes de error del servidor - mensaje {string|null} Mensaje de
    éxito (opcional) %>

    <% const titulo='Cambiar Contraseña' ; %>

        <div class="admin-formulario">
            <!-- Encabezado -->
            <div class="admin-formulario__encabezado">
                <a href="/usuarios/perfil" class="admin-formulario__volver">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="15 18 9 12 15 6"></polyline>
                    </svg>
                    Volver a mi perfil
                </a>
                <div class="admin-formulario__titulo-bloque">
                    <h1 class="admin-formulario__titulo">
                        <%= titulo %>
                    </h1>
                    <span class="admin-formulario__badge admin-formulario__badge--edicion">
                        Seguridad
                    </span>
                </div>
                <p class="campo-formulario__ayuda">Actualizá tu contraseña para mantener tu cuenta segura</p>
            </div>

            <!-- Mensaje de éxito -->
            <% if (mensaje) { %>
                <div class="admin-alerta admin-alerta--exito" role="alert">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                        <polyline points="22 4 12 14.01 9 11.01" />
                    </svg>
                    <%= mensaje %>
                </div>
                <% } %>

                    <!-- Errores del servidor -->
                    <%- include('../../partials/admin/_error-summary.ejs', { errores: errores }) %>

                        <!-- Formulario -->
                        <form action="/usuarios/cambiar-password?_method=PUT" method="POST" id="formCambiarPassword"
                            novalidate>
                            <input type="hidden" name="_method" value="PUT">

                            <div class="admin-formulario__layout">
                                <!-- COLUMNA PRINCIPAL -->
                                <div class="admin-formulario__columna-principal">

                                    <!-- Sección: Cambiar contraseña -->
                                    <div class="admin-formulario__seccion">
                                        <h2 class="admin-formulario__seccion-titulo">
                                            <span class="admin-formulario__seccion-icono">🔐</span>
                                            Cambiar contraseña
                                        </h2>

                                        <!-- Contraseña actual -->
                                        <div class="campo-formulario">
                                            <label class="etiqueta-campo" for="passwordActual">
                                                Contraseña actual <span class="campo-requerido">*</span>
                                            </label>
                                            <div class="contenedor-entrada">
                                                <input type="password" id="passwordActual" name="passwordActual"
                                                    class="entrada" placeholder="••••••••" required autofocus>
                                                <button type="button" class="boton-visibilidad"
                                                    aria-label="Mostrar contraseña" data-target="passwordActual">
                                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2">
                                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                        <circle cx="12" cy="12" r="3" />
                                                    </svg>
                                                </button>
                                            </div>
                                            <span class="mensaje-error" id="error-passwordActual"></span>
                                            <p class="campo-formulario__ayuda">Ingresá tu contraseña actual para
                                                verificar tu identidad.</p>
                                        </div>

                                        <!-- Nueva contraseña -->
                                        <div class="campo-formulario">
                                            <label class="etiqueta-campo" for="passwordNuevo">
                                                Nueva contraseña <span class="campo-requerido">*</span>
                                            </label>
                                            <div class="contenedor-entrada">
                                                <input type="password" id="passwordNuevo" name="passwordNuevo"
                                                    class="entrada" placeholder="••••••••" minlength="6" required>
                                                <button type="button" class="boton-visibilidad"
                                                    aria-label="Mostrar contraseña" data-target="passwordNuevo">
                                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2">
                                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                        <circle cx="12" cy="12" r="3" />
                                                    </svg>
                                                </button>
                                            </div>
                                            <span class="mensaje-error" id="error-passwordNuevo"></span>
                                            <p class="campo-formulario__ayuda">Mínimo 6 caracteres. Usá letras, números
                                                y símbolos para mayor seguridad.</p>
                                        </div>

                                        <!-- Confirmar nueva contraseña -->
                                        <div class="campo-formulario">
                                            <label class="etiqueta-campo" for="passwordConfirmar">
                                                Confirmar nueva contraseña <span class="campo-requerido">*</span>
                                            </label>
                                            <div class="contenedor-entrada">
                                                <input type="password" id="passwordConfirmar" name="passwordConfirmar"
                                                    class="entrada" placeholder="••••••••" minlength="6" required>
                                                <button type="button" class="boton-visibilidad"
                                                    aria-label="Mostrar contraseña" data-target="passwordConfirmar">
                                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"
                                                        stroke="currentColor" stroke-width="2">
                                                        <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                                        <circle cx="12" cy="12" r="3" />
                                                    </svg>
                                                </button>
                                            </div>
                                            <span class="mensaje-error" id="error-passwordConfirmar"></span>
                                        </div>
                                    </div>

                                    <!-- Sección: Requisitos de seguridad -->
                                    <div class="admin-formulario__seccion">
                                        <h2 class="admin-formulario__seccion-titulo">
                                            <span class="admin-formulario__seccion-icono">🛡️</span>
                                            Requisitos de seguridad
                                        </h2>
                                        <ul class="requisitos-lista">
                                            <li class="requisito-item" id="requisito-longitud">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2">
                                                    <circle cx="12" cy="12" r="10" />
                                                    <polyline points="12 6 12 12 16 14" />
                                                </svg>
                                                <span>Mínimo 6 caracteres</span>
                                            </li>
                                            <li class="requisito-item" id="requisito-mayuscula">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2">
                                                    <circle cx="12" cy="12" r="10" />
                                                    <polyline points="12 6 12 12 16 14" />
                                                </svg>
                                                <span>Al menos una letra mayúscula</span>
                                            </li>
                                            <li class="requisito-item" id="requisito-minuscula">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2">
                                                    <circle cx="12" cy="12" r="10" />
                                                    <polyline points="12 6 12 12 16 14" />
                                                </svg>
                                                <span>Al menos una letra minúscula</span>
                                            </li>
                                            <li class="requisito-item" id="requisito-numero">
                                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                    stroke="currentColor" stroke-width="2">
                                                    <circle cx="12" cy="12" r="10" />
                                                    <polyline points="12 6 12 12 16 14" />
                                                </svg>
                                                <span>Al menos un número</span>
                                            </li>
                                        </ul>
                                        <p class="campo-formulario__ayuda" style="margin-top: var(--espacio-md);">
                                            Una contraseña segura ayuda a proteger tu cuenta contra accesos no
                                            autorizados.
                                        </p>
                                    </div>
                                </div>

                                <!-- COLUMNA LATERAL -->
                                <aside class="admin-formulario__lateral">

                                    <!-- Card: Consejos de seguridad -->
                                    <div class="admin-lateral__card">
                                        <h3 class="admin-lateral__card-titulo">Consejos de seguridad</h3>
                                        <ul class="metadata-lista">
                                            <li class="metadata-item">
                                                <span class="metadata-item__valor">🔒 No compartas tu contraseña con
                                                    nadie</span>
                                            </li>
                                            <li class="metadata-item">
                                                <span class="metadata-item__valor">🔄 Cambiá tu contraseña
                                                    periódicamente</span>
                                            </li>
                                            <li class="metadata-item">
                                                <span class="metadata-item__valor">🚫 No uses la misma contraseña en
                                                    múltiples sitios</span>
                                            </li>
                                            <li class="metadata-item">
                                                <span class="metadata-item__valor">💡 Usá una combinación de letras,
                                                    números y símbolos</span>
                                            </li>
                                        </ul>
                                    </div>

                                    <!-- Card: Información adicional -->
                                    <div class="admin-lateral__card admin-lateral__card--metadata">
                                        <h3 class="admin-lateral__card-titulo">¿Qué pasa después?</h3>
                                        <ul class="metadata-lista">
                                            <li class="metadata-item">
                                                <span class="metadata-item__valor">✅ Tu sesión se mantendrá
                                                    activa</span>
                                            </li>
                                            <li class="metadata-item">
                                                <span class="metadata-item__valor">🔐 La próxima vez deberás usar la
                                                    nueva contraseña</span>
                                            </li>
                                            <li class="metadata-item">
                                                <span class="metadata-item__valor">📧 Recibirás un email de
                                                    confirmación</span>
                                            </li>
                                        </ul>
                                    </div>
                                </aside>
                            </div>

                            <!-- Barra de acciones fija -->
                            <div class="admin-formulario__acciones">
                                <a href="/usuarios/perfil" class="boton boton--secundario">Cancelar</a>
                                <button type="submit" class="boton boton--primario">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2">
                                        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z">
                                        </path>
                                        <polyline points="17 21 17 13 7 13 7 21"></polyline>
                                        <polyline points="7 3 7 8 15 8"></polyline>
                                    </svg>
                                    Cambiar contraseña
                                </button>
                            </div>
                        </form>
        </div>