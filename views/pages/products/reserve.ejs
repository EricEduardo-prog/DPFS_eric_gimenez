<%
  let subtotal = 0;
  let totalServicios = 0;
  let totalDescuento = 0;

  //  Separar items en productos y servicios para mostrar en secciones distintas
  const productosItems = (items || []).filter(item => item.productoId && !item.servicioId);
  const serviciosItems = (items || []).filter(item => item.servicioId && !item.productoId);

  //  Calcular subtotal de productos
  for (const item of items || []) {
      subtotal += (item.precioUnitario || 0) * item.cantidad;
  }

   //  Calcular total de servicios
  for (const item of serviciosItems) {
      totalServicios += (item.precioUnitario || 0);
  }
  
  // Calcular total de descuentos (si hay descuentos)
  const total = subtotal + totalServicios - totalDescuento;
%>

  <div class="reserva-container">
    <div class="reserva-header">
      <h1 class="reserva-titulo">Mi Reserva</h1>
      <p class="reserva-subtitulo">Revisá los productos y servicios seleccionados</p>
    </div>

    <% if (!items || items.length===0) { %>
      <div class="reserva-vacio">
        <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="9" cy="21" r="1"></circle>
          <circle cx="20" cy="21" r="1"></circle>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
        </svg>
        <h2>Tu reserva está vacía</h2>
        <p>Agregá productos para comenzar</p>
        <a href="/productos" class="btn-volver-tienda">Volver a la tienda</a>
      </div>
      <% } else { %>
        <div class="reserva-grid">
          <!-- COLUMNA PRINCIPAL -->
          <div class="reserva-items">

            <!-- Productos -->
            <div class="acordeon-seccion">
              <button class="acordeon-header" data-seccion="productos">
                <div class="acordeon-titulo">
                  <span class="acordeon-icono">📦</span>
                  <span>Productos</span>
                  <span class="acordeon-conteo">
                    <%= productosItems.length %>
                  </span>
                </div>
                <svg class="acordeon-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <div class="acordeon-contenido">
                <% if (productosItems.length===0) { %>
                  <div class="seccion-vacia">No hay productos agregados</div>
                  <% } else { %>
                    <% productosItems.forEach(function(item) { %>
                      <article class="reserva-item" data-item-id="<%= item.id %>">
                        <div class="item-imagen">
                          <div class="item-imagen-placeholder">🛍️</div>
                        </div>
                        <div class="item-info">
                          <h3 class="item-nombre">
                            <%= item.nombre || 'Producto' %>
                          </h3>
                          <p class="item-sku">ID: <%= item.productoId %>
                          </p>
                          <div class="item-acciones">
                            <div class="selector-cantidad">
                              <button class="btn-cantidad btn-disminuir" data-item-id="<%= item.id %>">−</button>
                              <input type="number" class="input-cantidad" value="<%= item.cantidad %>" min="1" readonly
                                data-item-id="<%= item.id %>">
                              <button class="btn-cantidad btn-aumentar" data-item-id="<%= item.id %>">+</button>
                            </div>
                            <button class="btn-eliminar" data-item-id="<%= item.id %>">Eliminar</button>
                          </div>
                        </div>
                        <div class="item-precio">
                          <span class="precio-unitario">$<%= (item.precioUnitario || 0).toLocaleString('es-AR') %>
                              </span>
                          <span class="precio-total">$<%= ((item.precioUnitario || 0) *
                              item.cantidad).toLocaleString('es-AR') %></span>
                        </div>
                      </article>
                      <% }); %>
                        <% } %>
              </div>
            </div>

            <!-- Servicios -->
            <div class="acordeon-seccion">
              <button class="acordeon-header" data-seccion="servicios">
                <div class="acordeon-titulo">
                  <span class="acordeon-icono">🔧</span>
                  <span>Servicios</span>
                  <span class="acordeon-conteo">
                    <%= serviciosItems.length %>
                  </span>
                </div>
                <svg class="acordeon-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <div class="acordeon-contenido">
                <% if (serviciosItems.length===0) { %>
                  <div class="seccion-vacia">No hay servicios agregados</div>
                  <% } else { %>
                    <% serviciosItems.forEach(function(item) { %>
                      <article class="reserva-item servicio-item" data-item-id="<%= item.id %>">
                        <div class="item-imagen">
                          <div class="item-imagen-placeholder">🛠️</div>
                        </div>
                        <div class="item-info">
                          <h3 class="item-nombre">
                            <%= item.nombre || 'Servicio' %>
                          </h3>
                          <p class="item-sku">ID: <%= item.servicioId %>
                          </p>

                          <!-- ✅ MOSTRAR PROFESIONAL ASIGNADO (si existe) -->
                          <% if (item.profesionalId && item.profesionalNombre) { %>
                            <div class="profesional-asignado">
                              <span class="profesional-icono">👨‍🔧</span>
                              <span class="profesional-nombre">
                                <%= item.profesionalNombre %>
                              </span>
                              <% if (item.profesionalRating) { %>
                                <span class="profesional-rating">★ <%= item.profesionalRating.toFixed(1) %></span>
                                <% } %>
                            </div>
                            <% } else if (item.profesionalId) { %>
                              <div class="profesional-asignado">
                                <span class="profesional-icono">👨‍🔧</span>
                                <span class="profesional-nombre">Profesional ID: <%= item.profesionalId %></span>
                              </div>
                              <% } %>

                                <!-- ✅ MOSTRAR FECHA Y HORARIO DE INSTALACIÓN (si existe) -->
                                <% if (item.fechaInstalacion) { %>
                                  <div class="fecha-instalacion-info">
                                    <span class="fecha-icono">📅</span>
                                    <span class="fecha-texto">
                                      <%= new Date(item.fechaInstalacion).toLocaleDateString('es-AR') %>
                                    </span>
                                    <% if (item.horarioInstalacion) { %>
                                      <span class="horario-texto"> - <%= item.horarioInstalacion==='manana'
                                          ? 'Mañana (08:00-13:00)' : 'Tarde (13:00-18:00)' %></span>
                                      <% } %>
                                  </div>
                                  <% } %>

                                    <div class="item-acciones">
                                      <button class="btn-eliminar" data-item-id="<%= item.id %>">Eliminar</button>
                                    </div>
                        </div>
                        <div class="item-precio">
                          <% if (item.precioUnitario && item.precioUnitario> 0) { %>
                            <span class="precio-unitario">$<%= item.precioUnitario.toLocaleString('es-AR') %></span>
                            <span class="precio-total">$<%= (item.precioUnitario * (item.cantidad ||
                                1)).toLocaleString('es-AR') %></span>
                            <% } else { %>
                              <span class="precio-unitario">A cotizar</span>
                              <span class="precio-total">—</span>
                              <% } %>
                        </div>
                      </article>
                      <% }); %>
                        <% } %>
              </div>
            </div>

            <!-- COLUMNA LATERAL - Resumen -->
            <aside class="resumen-pedido">
              <h2 class="resumen-titulo">Resumen del pedido</h2>

              <div class="resumen-detalles">
                <div class="linea-resumen">
                  <span>Subtotal (<%= (items || []).length %> items)</span>
                  <span class="monto">$<%= subtotal.toLocaleString('es-AR') %></span>
                </div>
                <div class="linea-resumen">
                  <span>Servicios</span>
                  <span class="monto">$<%= totalServicios.toLocaleString('es-AR') %></span>
                </div>
                <div class="linea-resumen">
                  <span>Envío</span>
                  <span class="monto gratis">GRATIS</span>
                </div>

                <div class="separador"></div>

                <div class="linea-total">
                  <span>Total a pagar</span>
                  <span class="monto-total">$<%= total.toLocaleString('es-AR') %></span>
                </div>
              </div>

              <div class="opciones-pago">
                <div class="opcion-pago">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="1" y="4" width="22" height="16" rx="2" ry="2"></rect>
                    <line x1="1" y1="10" x2="23" y2="10"></line>
                  </svg>
                  <span>Hasta 12 cuotas sin interés</span>
                </div>
              </div>

              <% if (esUsuario) { %>
                <button class="btn-finalizar" id="btnFinalizarCompra">
                  <span>Finalizar reserva</span>
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </button>
                <% } else { %>
                  <div class="aviso-login">
                    <p>Para finalizar tu reserva, necesitás</p>
                    <a href="/login?redirect=/reserva" class="btn-login">Iniciar sesión</a>
                    <p class="texto-pequeno">¿No tenés cuenta? <a href="/register">Registrate</a></p>
                  </div>
                  <% } %>

                    <div class="beneficios">
                      <div class="beneficio-item">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                          <polyline points="22 4 12 14.01 9 11.01"></polyline>
                        </svg>
                        <span>Compra segura</span>
                      </div>
                      <div class="beneficio-item">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        <span>Garantía oficial</span>
                      </div>
                    </div>
            </aside>
          </div>
          <% } %>
        </div>

        <script src="/js/reserve.js"></script>