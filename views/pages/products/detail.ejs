<% 
    // Calcular descuento
    const tieneDescuento=producto.precioOriginal && producto.precioOriginal> producto.precio;
    const descuento = tieneDescuento ? Math.round(((producto.precioOriginal - producto.precio) /
    producto.precioOriginal) * 100) : 0;

    // Calcular rating
    const ratingValor = producto.rating?.valor || 0;
    const ratingEntero = Math.floor(ratingValor);
    const tieneMedia = ratingValor - ratingEntero >= 0.5;

    // Normalizar arrays
    const colores = Array.isArray(producto.colores)
    ? producto.colores.flatMap(c => String(c).split(',').map(s => s.trim()).filter(Boolean))
    : [];
    const talles = Array.isArray(producto.talles)
    ? producto.talles.flatMap(t => String(t).split(',').map(s => s.trim()).filter(Boolean))
    : [];
    const caracteristicas = Array.isArray(producto.caracteristicas)
    ? producto.caracteristicas
    : (producto.caracteristicas ? [producto.caracteristicas] : []);

    // Generar imágenes
    const imagenes = [producto.imagen, ...(producto.imagenes || [])].filter(img => img && img !== '-' && img !== '.');
    const imagenPrincipal = imagenes[0] || '/images/placeholder.png';

    // Instalación
    const instalacionDisponible = producto.instalacion?.disponible || false;
    const precioInstalacion = producto.instalacion?.precio || 0;

    // Pasar datos a JavaScript mediante data attributes
    const dataProducto = {
    id: producto.id,
    nombre: producto.nombre.replace(/'/g, "\\'"),
    precio: producto.precio,
    precioInstalacion: precioInstalacion,
    instalacionDisponible: instalacionDisponible
    };
    %>

    <div class="contenedor">
        <!-- Carrusel de imágenes -->
        <section class="carrusel-imagenes">
            <div class="imagen-principal">
                <img src="<%= imagenPrincipal %>" alt="<%= producto.nombre %>"
                    onerror="this.onerror=null;this.src='/images/placeholder.png'">
            </div>
            <% if (imagenes.length> 1) { %>
                <div class="miniaturas">
                    <% imagenes.forEach(function(img, idx) { %>
                        <button class="miniatura <%= idx === 0 ? 'activa' : '' %>" data-imagen="<%= img %>">
                            <img src="<%= img %>" alt="Miniatura <%= idx + 1 %>"
                                onerror="this.onerror=null;this.src='/images/placeholder.png'">
                        </button>
                        <% }); %>
                </div>
                <% } %>
        </section>

        <!-- Información del producto -->
        <section class="seccion-informacion">
            <!-- Encabezado -->
            <div class="encabezado-producto">
                <h1 class="nombre-producto">
                    <%= producto.nombre %>
                </h1>
                <div class="meta-producto">
                    <div class="rating-producto">
                        <div class="estrellas">
                            <% for (var i=1; i <=5; i++) { %>
                                <% if (i <=ratingEntero) { %>
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
                                        stroke="currentColor" stroke-width="2">
                                        <polygon
                                            points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2">
                                        </polygon>
                                    </svg>
                                    <% } else if (tieneMedia && i===ratingEntero + 1) { %>
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
                                            stroke="currentColor" stroke-width="2" opacity="0.5">
                                            <polygon
                                                points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2">
                                            </polygon>
                                        </svg>
                                        <% } else { %>
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                                stroke="currentColor" stroke-width="2">
                                                <polygon
                                                    points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2">
                                                </polygon>
                                            </svg>
                                            <% } %>
                                                <% } %>
                        </div>
                        <span class="valor-rating">
                            <%= ratingValor %>
                        </span>
                        <span class="cantidad-resenas">(<%= producto.rating?.cantidad || 0 %> reseñas)</span>
                    </div>
                    <div class="sku-producto">
                        <span class="etiqueta-sku">SKU:</span>
                        <span class="valor-sku">
                            <%= producto.sku %>
                        </span>
                    </div>
                </div>
            </div>

            <!-- Precios -->
            <div class="seccion-precios">
                <div class="precio-actual">
                    <span class="monto" data-precio="<%= producto.precio %>">$<%=
                            producto.precio.toLocaleString('es-AR') %></span>
                    <% if (tieneDescuento) { %>
                        <span class="precio-anterior">$<%= producto.precioOriginal.toLocaleString('es-AR') %></span>
                        <span class="badge-descuento">-<%= descuento %>%</span>
                        <% } %>
                </div>
                <div class="opciones-pago">
                    <div class="opcion-pago-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <rect x="1" y="3" width="15" height="13"></rect>
                            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                            <circle cx="5.5" cy="18.5" r="2.5"></circle>
                            <circle cx="18.5" cy="18.5" r="2.5"></circle>
                        </svg>
                        <span>Hasta 12 cuotas sin interés</span>
                    </div>
                    <div class="opcion-pago-item">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                        </svg>
                        <span>Pago en efectivo: $<%= Math.round(producto.precio * 0.95).toLocaleString('es-AR') %>
                        </span>
                    </div>
                </div>
            </div>

            <!-- Selector de cantidad -->
            <div class="selector-cantidad">
                <button type="button" class="boton-cantidad" aria-label="Disminuir cantidad">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                </button>
                <input type="number" id="cantidadProducto" value="1" min="1" max="99" class="input-cantidad"
                    aria-label="Cantidad">
                <button type="button" class="boton-cantidad" aria-label="Aumentar cantidad">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                </button>
            </div>

            <!-- Instalación (solo si disponible) -->
            <% if (instalacionDisponible) { %>
                <div class="integracion-servicio" id="integracionServicio">
                    <div class="encabezado-servicio">
                        <div class="icono-titulo">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <path
                                    d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z">
                                </path>
                            </svg>
                            <h3 class="titulo-servicio">Instalación profesional</h3>
                        </div>
                    </div>

                    <div class="opcion-servicio opcion-activa">
                        <div class="contenido-opcion">
                            <div class="selector-opcion">
                                <input type="checkbox" id="checkboxInstalacion" class="checkbox-servicio" checked>
                                <div class="info-opcion">
                                    <label class="etiqueta-opcion">
                                        <span class="titulo-opcion">Incluir instalación</span>
                                    </label>
                                    <p class="descripcion-opcion">Instalación profesional certificada</p>
                                    <div class="indicadores-calidad">
                                        <span class="badge-calidad certificado">✅ Certificado</span>
                                        <span class="badge-calidad garantia">🔧 6 meses garantía</span>
                                    </div>
                                </div>
                            </div>
                            <% if (precioInstalacion> 0) { %>
                                <div class="precio-opcion">
                                    <span class="precio-servicio" data-precio-instalacion="<%= precioInstalacion %>">$
                                        <%= precioInstalacion.toLocaleString('es-AR') %>
                                    </span>
                                </div>
                                <% } %>
                        </div>
                    </div>

                    <div class="selector-fecha">
                        <div class="encabezado-fecha">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="2">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                <line x1="3" y1="10" x2="21" y2="10"></line>
                            </svg>
                            <h4 class="titulo-fecha">Fecha de instalación</h4>
                        </div>
                        <div class="fecha-seleccionada">
                            <div class="info-fecha">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="2">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                </svg>
                                <div>
                                    <span class="dia-fecha">Próxima fecha disponible</span>
                                    <span class="horario-fecha">Consultar disponibilidad</span>
                                </div>
                            </div>
                            <button class="boton-cambiar-fecha">Cambiar</button>
                        </div>
                    </div>
                </div>
                <% } %>

                    <!-- Total dinámico -->
                    <div class="seccion-total">
                        <div class="desglose-total">
                            <div class="linea-desglose" id="lineaProducto">
                                <span>Producto (1 unidad)</span>
                                <span class="monto" id="montoProducto">$<%= producto.precio.toLocaleString('es-AR') %>
                                </span>
                            </div>
                            <% if (instalacionDisponible && precioInstalacion> 0) { %>
                                <div class="linea-desglose" id="lineaInstalacion">
                                    <span>Instalación profesional</span>
                                    <span class="monto" id="montoInstalacion">$<%=
                                            precioInstalacion.toLocaleString('es-AR') %></span>
                                </div>
                                <% } %>
                                    <div class="linea-total">
                                        <span>Total a pagar</span>
                                        <span class="monto-total" id="montoTotal">$<%= (producto.precio +
                                                (instalacionDisponible ? precioInstalacion : 0)).toLocaleString('es-AR')
                                                %></span>
                                    </div>
                        </div>
                    </div>

                    <!-- Descripción y características -->
                    <div class="seccion-descripcion">
                        <h3 class="titulo-seccion-desc">Descripción</h3>
                        <p class="texto-descripcion">
                            <%= producto.descripcion %>
                        </p>

                        <% if (caracteristicas.length> 0) { %>
                            <h4 class="subtitulo-seccion">Características principales</h4>
                            <ul class="lista-caracteristicas">
                                <% caracteristicas.forEach(function(caract) { %>
                                    <li class="item-caracteristica">
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                                            stroke="currentColor" stroke-width="2">
                                            <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                                            <polyline points="22 4 12 14.01 9 11.01"></polyline>
                                        </svg>
                                        <span>
                                            <%= caract %>
                                        </span>
                                    </li>
                                    <% }); %>
                            </ul>
                            <% } %>

                                <% if (colores.length> 0 || talles.length > 0) { %>
                                    <div class="variantes">
                                        <% if (colores.length> 0) { %>
                                            <div class="variante-group">
                                                <label class="variante-label">Colores disponibles:</label>
                                                <div class="variante-opciones">
                                                    <% colores.forEach(function(color) { %>
                                                        <span class="opcion-talle">
                                                            <%= color %>
                                                        </span>
                                                        <% }); %>
                                                </div>
                                            </div>
                                            <% } %>
                                                <% if (talles.length> 0) { %>
                                                    <div class="variante-group">
                                                        <label class="variante-label">Talles disponibles:</label>
                                                        <div class="variante-opciones">
                                                            <% talles.forEach(function(talle) { %>
                                                                <span class="opcion-talle">
                                                                    <%= talle %>
                                                                </span>
                                                                <% }); %>
                                                        </div>
                                                    </div>
                                                    <% } %>
                                    </div>
                                    <% } %>
                    </div>
        </section>
    </div>

    <!-- Barra de acciones fija -->
    <div class="barra-acciones-producto">
        <div class="contenedor">
            <div class="contenido-barra-acciones">
                <button class="boton-carrito" id="btnAgregarReserva">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="9" cy="21" r="1"></circle>
                        <circle cx="20" cy="21" r="1"></circle>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                    </svg>
                    <span class="btn-texto">Agregar a reserva</span>
                    <span class="total-carrito" id="totalCarrito">$<%= (producto.precio + (instalacionDisponible ?
                            precioInstalacion : 0)).toLocaleString('es-AR') %></span>
                </button>
                <button class="boton-comprar" id="btnVerReservas">
                    <span>Ver reservas</span>
                </button>
            </div>
        </div>
    </div>

    <!-- Datos del producto para JavaScript -->
    <script>
        window.productoData = {
            id: '<%= dataProducto.id %>',
            nombre: '<%= dataProducto.nombre %>',
            precio: parseInt('<%= dataProducto.precio %>'),
            precioInstalacion: parseInt('<%= dataProducto.precioInstalacion %>'),
            instalacionDisponible: '<%= dataProducto.instalacionDisponible %>' === 'true'
        };
    </script>

    <!-- JavaScript externo -->
    <script src="/js/product-detail.js"></script>