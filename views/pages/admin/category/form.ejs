<%# Vista: pages/admin/category/form.ejs Controller: categoriaController.js → mostrarFormNueva() / mostrarFormEditar() /
  crear() / actualizar() Variables: - categoria {Object|null} null=alta, objeto=edición - errores {Array} Mensajes de
  error del servidor - formData {Object|null} Datos del body cuando hay error de validación %>

  <% const esEdicion=categoria && categoria.id; const datos=formData || categoria || {}; const titulo=esEdicion
    ? 'Editar Categoría' : 'Nueva Categoría' ; const formAction=esEdicion ?
    `/admin/categorias/${categoria.id}?_method=PUT` : '/admin/categorias' ; %>

    <section class="admin-formulario">
      <!-- Encabezado -->
      <div class="admin-formulario__encabezado">
        <a href="/admin/categorias" class="admin-formulario__volver">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          Volver al listado
        </a>
        <div class="admin-formulario__titulo-bloque">
          <h1 class="admin-formulario__titulo">
            <%= titulo %>
          </h1>
          <% if (esEdicion) { %>
            <span class="admin-formulario__badge admin-formulario__badge--edicion">Editando #<%= categoria.id %></span>
            <% } else { %>
              <span class="admin-formulario__badge admin-formulario__badge--nuevo">Nueva</span>
              <% } %>
        </div>
      </div>

      <!-- Errores del servidor -->
      <%- include('../../../partials/admin/_error-summary.ejs', { errores: errores }) %>

        <!-- Formulario -->
        <form action="<%= formAction %>" method="POST" id="formCategoria" novalidate>
          <% if (esEdicion) { %>
            <input type="hidden" name="_method" value="PUT">
            <input type="hidden" name="id" value="<%= categoria.id %>">
            <% } %>

              <div class="admin-formulario__layout">
                <!-- COLUMNA PRINCIPAL -->
                <div class="admin-formulario__columna-principal">
                  <div class="admin-formulario__seccion">
                    <h2 class="admin-formulario__seccion-titulo">
                      <span class="admin-formulario__seccion-icono">01</span>
                      Datos de la categoría
                    </h2>

                    <!-- Nombre -->
                    <div class="campo-formulario">
                      <label class="etiqueta-campo" for="nombre">
                        Nombre <span class="campo-requerido">*</span>
                      </label>
                      <input type="text" id="nombre" name="nombre" class="entrada" placeholder="Ej: Climatización"
                        value="<%= datos.name || '' %>" maxlength="80" required>
                      <span class="mensaje-error" id="error-nombre"></span>
                    </div>

                    <!-- Descripción con contador -->
                    <div class="campo-formulario">
                      <label class="etiqueta-campo" for="descripcion">
                        Descripción <span class="etiqueta-opcional">(opcional)</span>
                      </label>
                      <textarea id="descripcion" name="descripcion" class="entrada entrada--textarea"
                        placeholder="Describí brevemente esta categoría…" maxlength="200"
                        rows="3"><%= datos.description || '' %></textarea>
                      <div class="campo-formulario__pie">
                        <span class="campo-formulario__ayuda">Aparece en listados y filtros del sitio.</span>
                        <span class="contador-caracteres" id="contadorDesc">0 / 200</span>
                      </div>
                      <span class="mensaje-error" id="error-descripcion"></span>
                    </div>

                    <!-- Ícono y Orden -->
                    <div class="admin-formulario__fila-doble">
                      <div class="campo-formulario">
                        <label class="etiqueta-campo" for="icono">Ícono <span
                            class="etiqueta-opcional">(emoji)</span></label>
                        <input type="text" id="icono" name="icono" class="entrada" placeholder="Ej: ❄️"
                          value="<%= datos.icon || '' %>" maxlength="8">
                        <p class="campo-formulario__ayuda">Pegá un emoji que represente la categoría.</p>
                        <span class="mensaje-error" id="error-icono"></span>
                      </div>
                      <div class="campo-formulario">
                        <label class="etiqueta-campo" for="orden">Orden <span
                            class="etiqueta-opcional">(opcional)</span></label>
                        <input type="number" id="orden" name="orden" class="entrada entrada--numero" placeholder="Ej: 1"
                          min="1" value="<%= datos.order || '' %>">
                        <p class="campo-formulario__ayuda">Posición en el listado público.</p>
                        <span class="mensaje-error" id="error-orden"></span>
                      </div>
                    </div>
                  </div>
                </div>

                <!-- COLUMNA LATERAL -->
                <aside class="admin-formulario__lateral">
                  <!-- Card: Estado -->
                  <div class="admin-lateral__card">
                    <h3 class="admin-lateral__card-titulo">Estado</h3>
                    <%- include('../../../partials/admin/_toggle-switch.ejs', { id: 'activo' , name: 'activo' ,
                      label: 'Categoría activa' , helpText: 'Las categorías inactivas no aparecen en el sitio.' ,
                      checked: (!esEdicion || datos.activo===true) }) %>
                  </div>

                  <!-- Card: Metadata (solo edición) -->
                  <% if (esEdicion) { %>
                    <div class="admin-lateral__card admin-lateral__card--metadata">
                      <h3 class="admin-lateral__card-titulo">Información del registro</h3>
                      <ul class="metadata-lista">
                        <li class="metadata-item">
                          <span class="metadata-item__clave">ID</span>
                          <span class="metadata-item__valor metadata-item__valor--codigo">
                            <%= categoria.id %>
                          </span>
                        </li>
                        <li class="metadata-item">
                          <span class="metadata-item__clave">Slug</span>
                          <span class="metadata-item__valor metadata-item__valor--codigo">
                            <%= categoria.slug || '—' %>
                          </span>
                        </li>
                        <% if (categoria.createdAt) { %>
                          <li class="metadata-item">
                            <span class="metadata-item__clave">Creada</span>
                            <span class="metadata-item__valor">
                              <%= new Date(categoria.createdAt).toLocaleDateString('es-AR') %>
                            </span>
                          </li>
                          <% } %>
                            <% if (categoria.updatedAt) { %>
                              <li class="metadata-item">
                                <span class="metadata-item__clave">Modificada</span>
                                <span class="metadata-item__valor">
                                  <%= new Date(categoria.updatedAt).toLocaleDateString('es-AR') %>
                                </span>
                              </li>
                              <% } %>
                      </ul>
                    </div>
                    <% } %>
                </aside>
              </div>

              <!-- Barra de acciones fija -->
              <div class="admin-formulario__acciones">
                <a href="/admin/categorias" class="boton boton--secundario">Cancelar</a>
                <button type="submit" class="boton boton--primario">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                    <polyline points="17 21 17 13 7 13 7 21"></polyline>
                    <polyline points="7 3 7 8 15 8"></polyline>
                  </svg>
                  <%= esEdicion ? 'Guardar cambios' : 'Crear categoría' %>
                </button>
              </div>
        </form>
    </section>

    <!-- JavaScript externo -->
    <script src="/js/admin/category-form.js"></script>