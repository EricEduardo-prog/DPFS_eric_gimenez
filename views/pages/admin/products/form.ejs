<%# Vista: pages/admin/products/form.ejs Controller: productoController.js → mostrarFormNuevo() / mostrarFormEditar() /
  crear() / actualizar() Variables: - producto {Object|null} null=alta, objeto=edición - errores {Array} Mensajes de
  error del servidor - formData {Object|null} Datos del body cuando hay error de validación - categorias {Array} Lista
  de categorías activas para el <select> - servicios {Array} Lista de servicios de instalación habilitados para el
  selector en la sección de instalación. Si existe instalacion disponible, se debe seleccionar uno de estos servicios.
  %>

  <% const esEdicion=producto && producto.id; const datos=formData || producto || {}; const titulo=esEdicion
    ? 'Editar Producto' : 'Nuevo Producto' ; const formAction=esEdicion ? `/admin/productos/${producto.id}?_method=PUT`
    : '/admin/productos' ; // Calcular rating de forma segura (sin optional chaining) const ratingValor=(datos.rating &&
    datos.rating.valor) ? datos.rating.valor : 0; const ratingCantidad=(datos.rating && datos.rating.cantidad) ?
    datos.rating.cantidad : 0; %>

    <section class="admin-formulario">
      <!-- Encabezado -->
      <div class="admin-formulario__encabezado">
        <a href="/admin/productos" class="admin-formulario__volver">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
          Volver al listado
        </a>
        <div class="admin-formulario__titulo-bloque">
          <h1 class="admin-formulario__titulo">
            <%= titulo %>
          </h1>
          <% if (esEdicion) { %>
            <span class="admin-formulario__badge admin-formulario__badge--edicion">Editando #<%= producto.id %></span>
            <% } else { %>
              <span class="admin-formulario__badge admin-formulario__badge--nuevo">Nuevo</span>
              <% } %>
        </div>
      </div>

      <!-- ✅ Errores del servidor (usando partial unificado) -->
      <%- include('../../../partials/admin/_error-summary.ejs', { errores: errores }) %>

        <form action="<%= formAction %>" method="POST" id="formProducto" novalidate>
          <% if (esEdicion) { %>
            <input type="hidden" name="_method" value="PUT">
            <input type="hidden" name="id" value="<%= producto.id %>">
            <% } %>

              <div class="admin-formulario__layout">
                <!-- COLUMNA PRINCIPAL -->
                <div class="admin-formulario__columna-principal">

                  <!-- Sección: Información básica -->
                  <div class="admin-formulario__seccion">
                    <h2 class="admin-formulario__seccion-titulo">
                      <span class="admin-formulario__seccion-icono">01</span>
                      Información básica
                    </h2>

                    <!-- Nombre -->
                    <div class="campo-formulario">
                      <label class="etiqueta-campo" for="nombre">Nombre <span class="campo-requerido">*</span></label>
                      <input type="text" id="nombre" name="nombre" class="entrada"
                        placeholder="Ej: Aire acondicionado Split 3000W" value="<%= datos.name || '' %>" maxlength="120"
                        required>
                      <span class="mensaje-error" id="error-nombre"></span>
                    </div>

                    <!-- SKU -->
                    <div class="campo-formulario">
                      <label class="etiqueta-campo" for="sku">SKU <span class="campo-requerido">*</span></label>
                      <input type="text" id="sku" name="sku" class="entrada entrada--codigo"
                        placeholder="Ej: AC-SPLIT-3000" value="<%= datos.sku || '' %>" maxlength="50" required>
                      <span class="mensaje-error" id="error-sku"></span>
                    </div>

                    <!-- Categoría -->
                    <div class="campo-formulario">
                      <label class="etiqueta-campo" for="categoriaId">Categoría <span
                          class="campo-requerido">*</span></label>
                      <select id="categoriaId" name="categoriaId" class="entrada entrada--select" required>
                        <option value="">Seleccionar categoría...</option>
                        <% if (categorias && categorias.length> 0) { %>

                          <!-- Opciones de categoría -->
                          <% categorias.forEach(cat=> { %>
                            <option value="<%= cat.id %>" <%=(datos.categoriaId==cat.id) ? 'selected' : '' %>>
                              <%= cat.icon ? cat.icon + ' ' : '' %>
                                <%= cat.name %>
                            </option>
                            <% }); %>
                              <% } %>
                      </select>
                      <span class="mensaje-error" id="error-categoriaId"></span>
                    </div>

                    <!-- Descripción -->
                    <div class="campo-formulario">
                      <label class="etiqueta-campo" for="descripcion">Descripción <span
                          class="campo-requerido">*</span></label>
                      <textarea id="descripcion" name="descripcion" class="entrada entrada--textarea"
                        placeholder="Describe detalladamente el producto..." maxlength="600" rows="4"
                        required><%= datos.description || '' %></textarea>
                      <div class="campo-formulario__pie">
                        <span class="campo-formulario__ayuda">Aparece en la ficha del producto.</span>
                        <span class="contador-caracteres" id="contadorDesc">0 / 600</span>
                      </div>
                      <span class="mensaje-error" id="error-descripcion"></span>
                    </div>
                  </div>

                  <!-- Sección: Precios y costos -->
                  <div class="admin-formulario__seccion">
                    <h2 class="admin-formulario__seccion-titulo">
                      <span class="admin-formulario__seccion-icono">02</span>
                      Precios y costos
                    </h2>

                    <div class="admin-formulario__fila-doble">
                      <div class="campo-formulario">
                        <label class="etiqueta-campo" for="precio">Precio de venta <span
                            class="campo-requerido">*</span></label>
                        <div class="precio-input">
                          <span class="precio-input__simbolo">$</span>
                          <input type="number" id="precio" name="precio" class="entrada precio-input__campo"
                            placeholder="0.00" min="0.01" step="0.01" value="<%= datos.precio || '' %>" required>
                        </div>
                        <span class="mensaje-error" id="error-precio"></span>
                      </div>

                      <div class="campo-formulario">
                        <label class="etiqueta-campo" for="precioOriginal">Precio original <span
                            class="etiqueta-opcional">(opcional)</span></label>
                        <div class="precio-input">
                          <span class="precio-input__simbolo">$</span>
                          <input type="number" id="precioOriginal" name="precioOriginal"
                            class="entrada precio-input__campo" placeholder="0.00" min="0.01" step="0.01"
                            value="<%= datos.precioOriginal || '' %>">
                        </div>
                        <p class="campo-formulario__ayuda">Precio tachado (oferta).</p>
                        <span class="mensaje-error" id="error-precioOriginal"></span>
                      </div>
                    </div>
                  </div>

                  <!-- Sección: Imagen y multimedia -->
                  <div class="admin-formulario__seccion">
                    <h2 class="admin-formulario__seccion-titulo">
                      <span class="admin-formulario__seccion-icono">03</span>
                      Imagen y multimedia
                    </h2>

                    <div class="campo-formulario">
                      <label class="etiqueta-campo" for="imagen">URL de imagen <span
                          class="campo-requerido">*</span></label>
                      <input type="url" id="imagen" name="imagen" class="entrada"
                        placeholder="https://ejemplo.com/imagen.jpg" value="<%= datos.imagen || '' %>" required>
                      <p class="campo-formulario__ayuda">URL completa de la imagen principal del producto.</p>
                      <span class="mensaje-error" id="error-imagen"></span>
                    </div>

                    <%- include('../../../partials/admin/_image-preview-only.ejs', { imagenUrl: datos.imagen, altText:
                      datos.name || 'Vista previa del producto' }) %>
                  </div>

                  <!-- Sección: Variantes y opciones -->
                  <div class="admin-formulario__seccion">
                    <h2 class="admin-formulario__seccion-titulo">
                      <span class="admin-formulario__seccion-icono">04</span>
                      Variantes y opciones
                    </h2>

                    <%- include('../../../partials/admin/_chips-input.ejs', { idContenedor: 'contenedorColores' ,
                      idInput: 'inputColor' , idHidden: 'coloresHidden' , name: 'colores' , label: 'Colores' ,
                      placeholder: 'Ej: Blanco, Negro, Gris' , valoresIniciales: datos.colores }) %>

                      <%- include('../../../partials/admin/_chips-input.ejs', { idContenedor: 'contenedorTalles' ,
                        idInput: 'inputTalle' , idHidden: 'tallesHidden' , name: 'talles' , label: 'Talles' ,
                        placeholder: 'Ej: S, M, L, XL' , valoresIniciales: datos.talles }) %>
                  </div>
                </div>

                <!-- COLUMNA LATERAL -->
                <aside class="admin-formulario__lateral">

                  <!-- ✅ Card: Estado (usando partial _toggle-switch) -->
                  <div class="admin-lateral__card">
                    <h3 class="admin-lateral__card-titulo">Estado</h3>
                    <%- include('../../../partials/admin/_toggle-switch.ejs', { id: 'activo' , name: 'activo' ,
                      label: 'Producto activo' , helpText: 'Los productos inactivos no aparecen en el sitio.' , checked:
                      (!esEdicion || datos.is_active===true) }) %>
                  </div>

                  <!-- Card: Instalación -->
                  <div class="admin-lateral__card">
                    <h3 class="admin-lateral__card-titulo">Instalación</h3>

                    <div class="campo-formulario">
                      <div class="toggle-fila">
                        <div class="toggle-fila__info">
                          <label class="etiqueta-campo" for="instalacionDisponible">Instalación disponible</label>
                          <p class="campo-formulario__ayuda">¿Ofrecen servicio de instalación?</p>
                        </div>
                        <label class="toggle-switch">
                          <input type="checkbox" id="instalacionDisponible" name="instalacionDisponible" value="true"
                            <%=datos.installation_available===true || datos.installation_available==='true' ? 'checked'
                            : '' %>>
                          <span class="toggle-switch__slider"></span>
                        </label>
                      </div>
                    </div>

                    <div
                      class="instalacion-panel <%= datos.installation?.available===true || datos.installation?.available=== 'true' ? '' : 'oculto' %>"
                      id="instalacionPanel">

                      <!-- Selector de servicio de instalación -->
                      <div class="campo-formulario">
                        <label class="etiqueta-campo" for="instalacionServicioId">
                          Servicio de instalación <span class="campo-requerido">*</span>
                        </label>
                        <select id="instalacionServicioId" name="instalacionServicioId" class="entrada entrada--select"
                          <%=!datos.installation?.available ? 'disabled' : '' %>>
                          <option value="">-- Seleccionar servicio --</option>
                          <% if (servicios && servicios.length> 0) { %>
                            <% servicios.forEach(function(serv) { %>
                              <option value="<%= serv.id %>" <%=(datos.installation_service_id===serv.id) ? 'selected'
                                : '' %>>
                                <%= serv.name %>
                              </option>
                              <% }); %>
                                <% } else { %>
                                  <option value="" disabled>No hay servicios disponibles</option>
                                  <% } %>
                        </select>
                        <p class="campo-formulario__ayuda">Servicio que se asociará a la instalación del producto.</p>
                        <span class="mensaje-error" id="error-instalacionServicioId"></span>
                      </div>

                    </div>
                  </div>

              </div>
              </div>

              <!-- Card: Metadata (solo edición) -->
              <% if (esEdicion) { %>
                <div class="admin-lateral__card admin-lateral__card--metadata">
                  <h3 class="admin-lateral__card-titulo">Información del registro</h3>
                  <ul class="metadata-lista">
                    <li class="metadata-item">
                      <span class="metadata-item__clave">ID</span>
                      <span class="metadata-item__valor metadata-item__valor--codigo">
                        <%= producto.id %>
                      </span>
                    </li>
                    <li class="metadata-item">
                      <span class="metadata-item__clave">SKU</span>
                      <span class="metadata-item__valor metadata-item__valor--codigo">
                        <%= producto.sku %>
                      </span>
                    </li>
                    <li class="metadata-item">
                      <span class="metadata-item__clave">Rating</span>
                      <span class="metadata-item__valor">
                        <%= ratingValor %> (<%= ratingCantidad %> reseñas)
                      </span>
                    </li>
                    <% if (producto.created_at) { %>
                      <li class="metadata-item">
                        <span class="metadata-item__clave">Creado</span>
                        <span class="metadata-item__valor">
                          <%= new Date(producto.created_at).toLocaleDateString('es-AR') %>
                        </span>
                      </li>
                      <% } %>
                        <% if (producto.updated_at) { %>
                          <li class="metadata-item">
                            <span class="metadata-item__clave">Modificado</span>
                            <span class="metadata-item__valor">
                              <%= new Date(producto.updated_at).toLocaleDateString('es-AR') %>
                            </span>
                          </li>
                          <% } %>
                  </ul>
                </div>
                <% } %>
                  </aside>
                  </div>

                  <!-- Barra de acciones fija -->
                  <div class="admin-formulario__acciones">
                    <a href="/admin/productos" class="boton boton--secundario">Cancelar</a>
                    <button type="submit" class="boton boton--primario">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2">
                        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                        <polyline points="17 21 17 13 7 13 7 21"></polyline>
                        <polyline points="7 3 7 8 15 8"></polyline>
                      </svg>
                      <%= esEdicion ? 'Guardar cambios' : 'Crear producto' %>
                    </button>
                  </div>
        </form>
    </section>

    <!-- JavaScript externo -->
    <script src="/js/admin/product-form.js"></script>