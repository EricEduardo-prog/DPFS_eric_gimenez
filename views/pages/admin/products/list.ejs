<%# Vista: pages/admin/products/list.ejs Controller: productoController.js → listar() Variables: - productos {Array}
    Resultado de productoModel.getAll() - categorias {Array} Resultado de categoriaModel.getAll({ soloActivas: true }) -
    filtros {Object} { categoriaId: '' , soloActivos: '' } - mensaje {string|null} Query param ?mensaje=- error
    {string|null} Query param ?error=%>

    <div class="admin-listado">
        <!-- Encabezado -->
        <div class="admin-listado__encabezado">
            <div class="admin-listado__titulo-bloque">
                <h1 class="admin-listado__titulo">Productos</h1>
                <span class="admin-listado__conteo">
                    <%= productos.length %> registros
                </span>
            </div>
            <a href="/admin/productos/nuevo" class="boton boton--primario">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="12" y1="5" x2="12" y2="19" />
                    <line x1="5" y1="12" x2="19" y2="12" />
                </svg>
                Nuevo producto
            </a>
        </div>

        <!-- Alertas de feedback -->
        <% if (mensaje) { %>
            <div class="admin-alerta admin-alerta--exito" role="alert">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                    <polyline points="22 4 12 14.01 9 11.01" />
                </svg>
                <%= mensaje %>
            </div>
            <% } %>

                <% if (error) { %>
                    <div class="admin-alerta admin-alerta--error" role="alert">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                        <%= error %>
                    </div>
                    <% } %>

                        <!-- Filtros -->
                        <form class="admin-filtros" method="GET" action="/admin/productos" id="filtrosForm">
                            <div class="admin-filtros__grupo">
                                <select name="categoriaId" class="entrada entrada--select"
                                    style="width: auto; min-width: 200px;">
                                    <option value="">Todas las categorías</option>
                                    <% categorias.forEach(function(cat) { %>
                                        <option value="<%= cat.id %>" <%=filtros.categoriaId===cat.id ? 'selected' : ''
                                            %>>
                                            <%= cat.icon ? cat.icon + ' ' : '' %>
                                                <%= cat.name %>
                                        </option>
                                        <% }); %>
                                </select>

                                <label class="admin-filtros__check-label">
                                    <input type="checkbox" name="soloActivos" value="true"
                                        <%=filtros.soloActivos==='true' ? 'checked' : '' %>>
                                    Solo activos
                                </label>

                                <button type="submit" class="boton boton--secundario">Filtrar</button>
                                <a href="/admin/productos" class="boton boton--secundario">Limpiar</a>
                            </div>
                        </form>

                        <!-- Estado vacío -->
                        <% if (productos.length===0) { %>
                            <div class="admin-vacio">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                    stroke-width="1.3">
                                    <rect x="2" y="3" width="20" height="14" rx="2" />
                                    <line x1="8" y1="21" x2="16" y2="21" />
                                    <line x1="12" y1="17" x2="12" y2="21" />
                                </svg>
                                <p>No hay productos que coincidan con los filtros.</p>
                                <a href="/admin/productos/nuevo" class="boton boton--primario">Crear primer producto</a>
                            </div>
                            <% } else { %>
                                <!-- Tabla de productos -->
                                <div class="admin-tabla-contenedor">
                                    <table class="admin-tabla" id="productosTabla">
                                        <thead>
                                            <tr>
                                                <th class="sortable" data-sort="nombre">Producto <span
                                                        class="sort-icon">↕️</span></th>
                                                <th class="sortable" data-sort="sku">SKU <span
                                                        class="sort-icon">↕️</span></th>
                                                <th>Categoría</th>
                                                <th class="sortable" data-sort="precio">Precio <span
                                                        class="sort-icon">↕️</span></th>
                                                <th>Estado</th>
                                                <th>Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% productos.forEach(function(p) { %>
                                                <% const cat=categorias.find(function(c) { return c.id===p.category.id;
                                                    }); %>
                                                    <tr class="<%= !p.is_active ? 'admin-tabla__fila--inactiva' : '' %>"
                                                        data-nombre="<%= p.name.toLowerCase() %>"
                                                        data-sku="<%= p.sku.toLowerCase() %>"
                                                        data-precio="<%= p.price %>">

                                                        <!-- Producto (imagen + nombre) -->
                                                        <td class="admin-tabla__celda-producto">
                                                            <div class="admin-tabla__img-wrap">
                                                                <% if (p.image && p.image !=='-' &&
                                                                    p.image.startsWith('http')) { %>
                                                                    <img src="<%= p.image %>" alt="<%= p.name %>"
                                                                        class="admin-tabla__img"
                                                                        onerror="this.style.display='none';this.parentElement.querySelector('.admin-tabla__img-placeholder').style.display='flex'">
                                                                    <div class="admin-tabla__img-placeholder"
                                                                        style="display:none" aria-hidden="true">📦</div>
                                                                    <% } else { %>
                                                                        <div class="admin-tabla__img-placeholder"
                                                                            aria-hidden="true">📦</div>
                                                                        <% } %>
                                                            </div>
                                                            <div class="admin-tabla__producto-info">
                                                                <span class="admin-tabla__nombre">
                                                                    <%= p.name %>
                                                                </span>
                                                                <% if (p.installation_available &&
                                                                    p.installation_service_id) { %>
                                                                    <span
                                                                        class="admin-tabla__badge-mini admin-tabla__badge-mini--info">🔧
                                                                        Instalación</span>
                                                                    <% } %>
                                                            </div>
                                                        </td>

                                                        <!-- SKU -->
                                                        <td><code class="admin-tabla__codigo"><%= p.sku %></code></td>

                                                        <!-- Categoría -->
                                                        <td class="admin-tabla__celda-categoria">
                                                            <% if (cat) { %>
                                                                <span class="admin-tabla__icono-cat">
                                                                    <%= cat.icon || '📁' %>
                                                                </span>
                                                                <span>
                                                                    <%= cat.name %>
                                                                </span>
                                                                <% } else { %>
                                                                    <span class="admin-tabla__texto-suave">—</span>
                                                                    <% } %>
                                                        </td>

                                                        <!-- Precio -->
                                                        <td class="admin-tabla__precio">
                                                            $<%= p.price.toLocaleString('es-AR') %>
                                                                <% if (p.original_price && p.original_price> p.price) {
                                                                    %>
                                                                    <% const pct=Math.round(((p.original_price -
                                                                        p.price) / p.original_price) * 100); %>
                                                                        <span
                                                                            class="admin-tabla__badge-mini admin-tabla__badge-mini--descuento">-
                                                                            <%= pct %>%
                                                                        </span>
                                                                        <% } %>
                                                        </td>

                                                        <!-- Estado -->
                                                        <td>
                                                            <span
                                                                class="admin-estado-dot admin-estado-dot--<%= p.is_active ? 'activo' : 'inactivo' %>">
                                                                <%= p.is_active ? 'Activo' : 'Inactivo' %>
                                                            </span>
                                                        </td>

                                                        <!-- Acciones -->
                                                        <td>
                                                            <div class="admin-tabla__acciones">
                                                                <a href="/admin/productos/<%= p.id %>/editar"
                                                                    class="admin-tabla__btn-accion"
                                                                    title="Editar <%= p.name %>"
                                                                    aria-label="Editar <%= p.name %>">
                                                                    <svg width="14" height="14" viewBox="0 0 24 24"
                                                                        fill="none" stroke="currentColor"
                                                                        stroke-width="2">
                                                                        <path
                                                                            d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                                                        <path
                                                                            d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                                                    </svg>
                                                                </a>

                                                                <form action="/admin/productos/<%= p.id %>/baja"
                                                                    method="POST" class="form-toggle-estado"
                                                                    data-id="<%= p.id %>" data-nombre="<%= p.name %>"
                                                                    data-activo="<%= p.is_active %>">
                                                                    <input type="hidden" name="_method" value="DELETE">
                                                                    <button type="button"
                                                                        class="admin-tabla__btn-accion <%= p.is_active ? 'admin-tabla__btn-accion--baja' : 'admin-tabla__btn-accion--alta' %> btn-toggle-estado"
                                                                        title="<%= p.is_active ? 'Dar de baja' : 'Reactivar' %>"
                                                                        data-id="<%= p.id %>"
                                                                        data-nombre="<%= p.name %>"
                                                                        data-activo="<%= p.is_active %>">
                                                                        <% if (p.is_active) { %>
                                                                            <svg width="14" height="14"
                                                                                viewBox="0 0 24 24" fill="none"
                                                                                stroke="currentColor" stroke-width="2">
                                                                                <circle cx="12" cy="12" r="10" />
                                                                                <line x1="4.93" y1="4.93" x2="19.07"
                                                                                    y2="19.07" />
                                                                            </svg>
                                                                            <% } else { %>
                                                                                <svg width="14" height="14"
                                                                                    viewBox="0 0 24 24" fill="none"
                                                                                    stroke="currentColor"
                                                                                    stroke-width="2">
                                                                                    <path
                                                                                        d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                                                                                    <polyline
                                                                                        points="22 4 12 14.01 9 11.01" />
                                                                                </svg>
                                                                                <% } %>
                                                                    </button>
                                                                </form>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                    <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                                <% } %>
    </div>

    <!-- JavaScript externo -->
    <script src="/js/admin/product-list.js"></script>