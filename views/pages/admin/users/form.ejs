<%# Vista: pages/admin/users/form.ejs Controller: usuarioController.js → mostrarFormNuevo() / mostrarFormEditar() /
    crear() / actualizar() Variables: - usuario {Object|null} null=alta, objeto=edición - errores {Array} Mensajes de
    error del servidor - formData {Object|null} Datos del body cuando hay error de validación %>

    <% const esEdicion=usuario && usuario.id; const datos=formData || usuario || {}; const titulo=esEdicion
        ? 'Editar Usuario' : 'Nuevo Usuario' ; const formAction=esEdicion ? `/admin/usuarios/${usuario.id}?_method=PUT`
        : '/admin/usuarios' ; %>

        <section class="admin-formulario">
            <!-- Encabezado -->
            <div class="admin-formulario__encabezado">
                <a href="/admin/usuarios" class="admin-formulario__volver">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="15 18 9 12 15 6"></polyline>
                    </svg>
                    Volver al listado
                </a>
                <div class="admin-formulario__titulo-bloque">
                    <h1 class="admin-formulario__titulo">
                        <%= titulo %>
                    </h1>
                    <% if (esEdicion) { %>
                        <span class="admin-formulario__badge admin-formulario__badge--edicion">Editando #<%= usuario.id
                                %></span>
                        <% } else { %>
                            <span class="admin-formulario__badge admin-formulario__badge--nuevo">Nuevo</span>
                            <% } %>
                </div>
            </div>

            <!-- Errores del servidor -->
            <%- include('../../../partials/admin/_error-summary.ejs', { errores: errores }) %>

                <form action="<%= formAction %>" method="POST" id="formUsuario" novalidate>
                    <% if (esEdicion) { %>
                        <input type="hidden" name="_method" value="PUT">
                        <input type="hidden" name="id" value="<%= usuario.id %>">
                        <% } %>

                            <div class="admin-formulario__layout">
                                <!-- COLUMNA PRINCIPAL -->
                                <div class="admin-formulario__columna-principal">

                                    <!-- Sección: Datos personales -->
                                    <div class="admin-formulario__seccion">
                                        <h2 class="admin-formulario__seccion-titulo">
                                            <span class="admin-formulario__seccion-icono">01</span>
                                            Datos personales
                                        </h2>

                                        <!-- Nombre -->
                                        <div class="campo-formulario">
                                            <label class="etiqueta-campo" for="nombre">Nombre completo <span
                                                    class="campo-requerido">*</span></label>
                                            <input type="text" id="nombre" name="nombre" class="entrada"
                                                placeholder="Ej: María García" value="<%= datos.nombre || '' %>"
                                                maxlength="100" required>
                                            <span class="mensaje-error" id="error-nombre"></span>
                                        </div>

                                        <!-- Email -->
                                        <div class="campo-formulario">
                                            <label class="etiqueta-campo" for="email">Email <span
                                                    class="campo-requerido">*</span></label>
                                            <input type="email" id="email" name="email" class="entrada"
                                                placeholder="usuario@ejemplo.com" value="<%= datos.email || '' %>"
                                                required <%=esEdicion ? 'readonly' : '' %>>
                                            <p class="campo-formulario__ayuda">El email es único y no se puede modificar
                                                después de crear la cuenta.</p>
                                            <span class="mensaje-error" id="error-email"></span>
                                        </div>

                                        <!-- Contraseña (solo en creación o si se quiere cambiar) -->
                                        <div class="campo-formulario">
                                            <label class="etiqueta-campo" for="password">
                                                Contraseña <span class="campo-requerido">
                                                    <%= !esEdicion ? '*' : '(opcional)' %>
                                                </span>
                                            </label>
                                            <input type="password" id="password" name="password" class="entrada"
                                                placeholder="<%= esEdicion ? 'Dejar vacío para mantener la actual' : 'Mínimo 6 caracteres' %>"
                                                minlength="6">
                                            <p class="campo-formulario__ayuda">Mínimo 6 caracteres. Recomendado: letras,
                                                números y símbolos.</p>
                                            <span class="mensaje-error" id="error-password"></span>
                                        </div>

                                        <!-- Teléfono -->
                                        <div class="campo-formulario">
                                            <label class="etiqueta-campo" for="telefono">Teléfono <span
                                                    class="etiqueta-opcional">(opcional)</span></label>
                                            <input type="tel" id="telefono" name="telefono" class="entrada"
                                                placeholder="Ej: +54 9 223 456-7890"
                                                value="<%= datos.telefono || '' %>">
                                            <span class="mensaje-error" id="error-telefono"></span>
                                        </div>
                                    </div>

                                    <!-- Sección: Dirección -->
                                    <div class="admin-formulario__seccion">
                                        <h2 class="admin-formulario__seccion-titulo">
                                            <span class="admin-formulario__seccion-icono">02</span>
                                            Dirección
                                        </h2>

                                        <div class="admin-formulario__fila-doble">
                                            <div class="campo-formulario">
                                                <label class="etiqueta-campo" for="direccion_calle">Calle</label>
                                                <input type="text" id="direccion_calle" name="direccion_calle"
                                                    class="entrada" placeholder="Ej: Av. Colón"
                                                    value="<%= datos.direccion?.calle || '' %>">
                                            </div>
                                            <div class="campo-formulario">
                                                <label class="etiqueta-campo" for="direccion_numero">Número</label>
                                                <input type="text" id="direccion_numero" name="direccion_numero"
                                                    class="entrada" placeholder="Ej: 1234"
                                                    value="<%= datos.direccion?.numero || '' %>">
                                            </div>
                                        </div>

                                        <div class="admin-formulario__fila-doble">
                                            <div class="campo-formulario">
                                                <label class="etiqueta-campo" for="direccion_piso">Piso</label>
                                                <input type="text" id="direccion_piso" name="direccion_piso"
                                                    class="entrada" placeholder="Ej: 3"
                                                    value="<%= datos.direccion?.piso || '' %>">
                                            </div>
                                            <div class="campo-formulario">
                                                <label class="etiqueta-campo" for="direccion_depto">Departamento</label>
                                                <input type="text" id="direccion_depto" name="direccion_depto"
                                                    class="entrada" placeholder="Ej: B"
                                                    value="<%= datos.direccion?.depto || '' %>">
                                            </div>
                                        </div>

                                        <div class="admin-formulario__fila-doble">
                                            <div class="campo-formulario">
                                                <label class="etiqueta-campo" for="direccion_ciudad">Ciudad</label>
                                                <input type="text" id="direccion_ciudad" name="direccion_ciudad"
                                                    class="entrada" placeholder="Ej: Mar del Plata"
                                                    value="<%= datos.direccion?.ciudad || '' %>">
                                            </div>
                                            <div class="campo-formulario">
                                                <label class="etiqueta-campo"
                                                    for="direccion_provincia">Provincia</label>
                                                <input type="text" id="direccion_provincia" name="direccion_provincia"
                                                    class="entrada" placeholder="Ej: Buenos Aires"
                                                    value="<%= datos.direccion?.provincia || '' %>">
                                            </div>
                                        </div>

                                        <div class="campo-formulario">
                                            <label class="etiqueta-campo" for="direccion_codigoPostal">Código
                                                Postal</label>
                                            <input type="text" id="direccion_codigoPostal" name="direccion_codigoPostal"
                                                class="entrada" placeholder="Ej: 7600"
                                                value="<%= datos.direccion?.codigoPostal || '' %>">
                                        </div>
                                    </div>
                                </div>

                                <!-- COLUMNA LATERAL -->
                                <aside class="admin-formulario__lateral">

                                    <!-- Card: Estado -->
                                    <div class="admin-lateral__card">
                                        <h3 class="admin-lateral__card-titulo">Estado</h3>
                                        <%- include('../../../partials/admin/_toggle-switch.ejs', { id: 'activo' ,
                                            name: 'activo' , label: 'Usuario activo' ,
                                            helpText: 'Los usuarios inactivos no pueden iniciar sesión.' , checked:
                                            (!esEdicion || datos.activo===true) }) %>
                                    </div>

                                    <!-- Card: Términos y condiciones -->
                                    <div class="admin-lateral__card">
                                        <h3 class="admin-lateral__card-titulo">Términos</h3>
                                        <div class="campo-formulario">
                                            <label class="toggle-fila">
                                                <div class="toggle-fila__info">
                                                    <span class="etiqueta-campo">Aceptó términos y condiciones</span>
                                                    <p class="campo-formulario__ayuda">El usuario aceptó los términos al
                                                        registrarse.</p>
                                                </div>
                                                <label class="toggle-switch">
                                                    <input type="checkbox" name="aceptoTerminos" value="true"
                                                        <%=datos.aceptoTerminos ? 'checked' : '' %>
                                                    <%= esEdicion ? '' : 'required' %>>
                                                        <span class="toggle-switch__slider"></span>
                                                </label>
                                            </label>
                                            <span class="mensaje-error" id="error-terminos"></span>
                                        </div>
                                    </div>

                                    <!-- Card: Metadata (solo edición) -->
                                    <% if (esEdicion) { %>
                                        <div class="admin-lateral__card admin-lateral__card--metadata">
                                            <h3 class="admin-lateral__card-titulo">Información del registro</h3>
                                            <ul class="metadata-lista">
                                                <li class="metadata-item">
                                                    <span class="metadata-item__clave">ID</span>
                                                    <span class="metadata-item__valor metadata-item__valor--codigo">
                                                        <%= usuario.id %>
                                                    </span>
                                                </li>
                                                <li class="metadata-item">
                                                    <span class="metadata-item__clave">Email</span>
                                                    <span class="metadata-item__valor">
                                                        <%= usuario.email %>
                                                    </span>
                                                </li>
                                                <% if (usuario.fechaRegistro) { %>
                                                    <li class="metadata-item">
                                                        <span class="metadata-item__clave">Registrado</span>
                                                        <span class="metadata-item__valor">
                                                            <%= new
                                                                Date(usuario.fechaRegistro).toLocaleDateString('es-AR')
                                                                %>
                                                        </span>
                                                    </li>
                                                    <% } %>
                                                        <% if (usuario.fechaModificacion) { %>
                                                            <li class="metadata-item">
                                                                <span class="metadata-item__clave">Modificado</span>
                                                                <span class="metadata-item__valor">
                                                                    <%= new
                                                                        Date(usuario.fechaModificacion).toLocaleDateString('es-AR')
                                                                        %>
                                                                </span>
                                                            </li>
                                                            <% } %>
                                            </ul>
                                        </div>
                                        <% } %>
                                </aside>
                            </div>

                            <!-- Barra de acciones fija -->
                            <div class="admin-formulario__acciones">
                                <a href="/admin/usuarios" class="boton boton--secundario">Cancelar</a>
                                <button type="submit" class="boton boton--primario">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2">
                                        <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z">
                                        </path>
                                        <polyline points="17 21 17 13 7 13 7 21"></polyline>
                                        <polyline points="7 3 7 8 15 8"></polyline>
                                    </svg>
                                    <%= esEdicion ? 'Guardar cambios' : 'Registrar usuario' %>
                                </button>
                            </div>
                </form>
        </section>

        <!-- JavaScript externo -->
        <script src="/js/admin/user-form.js"></script>