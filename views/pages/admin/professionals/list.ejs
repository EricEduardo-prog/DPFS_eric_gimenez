<%# Vista: pages/admin/professionals/list.ejs Controller: profesionalesController.js → listar() Variables: -
  profesionales {Array} Lista de profesionales - servicios {Array} Lista de servicios para el filtro - filtros {Object}
  { servicioId: '' , soloActivos: '' } - mensaje {string|null} - error {string|null} %>

  <div class="admin-listado">
    <!-- Encabezado -->
    <div class="admin-listado__encabezado">
      <div class="admin-listado__titulo-bloque">
        <h1 class="admin-listado__titulo">Profesionales</h1>
        <span class="admin-listado__conteo" id="registrosConteo">
          <%= profesionales.length %> registros
        </span>
      </div>
      <a href="/admin/profesionales/nuevo" class="boton boton--primario">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <line x1="12" y1="5" x2="12" y2="19" />
          <line x1="5" y1="12" x2="19" y2="12" />
        </svg>
        Nuevo profesional
      </a>
    </div>

    <!-- Alertas de feedback -->
    <% if (mensaje) { %>
      <div class="admin-alerta admin-alerta--exito" role="alert">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
          <polyline points="22 4 12 14.01 9 11.01" />
        </svg>
        <%= mensaje %>
      </div>
      <% } %>

        <% if (error) { %>
          <div class="admin-alerta admin-alerta--error" role="alert">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10" />
              <line x1="12" y1="8" x2="12" y2="12" />
              <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            <%= error %>
          </div>
          <% } %>

            <!-- Filtros -->
            <form class="admin-filtros" method="GET" action="/admin/profesionales" id="filtrosForm">
              <div class="admin-filtros__grupo">
                <select name="servicioId" class="entrada entrada--select" style="width: auto; min-width: 200px;">
                  <option value="">Todos los servicios</option>
                  <% if (servicios && servicios.length> 0) { %>
                    <% servicios.forEach(function(serv) { %>
                      <option value="<%= serv.id %>" <%=filtros.servicioId===serv.id ? 'selected' : '' %>>
                        <%= serv.icono || '🔧' %>
                          <%= serv.nombre %>
                      </option>
                      <% }); %>
                        <% } %>
                </select>

                <label class="admin-filtros__check-label">
                  <input type="checkbox" name="soloActivos" value="true" <%=filtros.soloActivos==='true' ? 'checked'
                    : '' %>>
                  Solo activos
                </label>

                <button type="submit" class="boton boton--secundario">Filtrar</button>
                <a href="/admin/profesionales" class="boton boton--secundario" id="limpiarFiltros">Limpiar</a>
              </div>
            </form>

            <!-- Estado vacío -->
            <% if (profesionales.length===0) { %>
              <div class="admin-vacio">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                  <circle cx="12" cy="7" r="4" />
                </svg>
                <p>No hay profesionales que coincidan con los filtros.</p>
                <a href="/admin/profesionales/nuevo" class="boton boton--primario">Registrar primer profesional</a>
              </div>
              <% } else { %>
                <!-- Tabla -->
                <div class="admin-tabla-contenedor">
                  <table class="admin-tabla" id="profesionalesTabla">
                    <thead>
                      <tr>
                        <th class="sortable" data-sort="nombre">Profesional <span class="sort-icon">↕️</span></th>
                        <th class="sortable" data-sort="matricula">Matrícula <span class="sort-icon">↕️</span></th>
                        <th class="sortable" data-sort="servicio">Servicio <span class="sort-icon">↕️</span></th>
                        <th>Estado Servicio</th>
                        <th>Contacto</th>
                        <th class="sortable" data-sort="valoracion">Valoración <span class="sort-icon">↕️</span></th>
                        <th>Disponibilidad</th>
                        <th>Estado</th>
                        <th>Acciones</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% profesionales.forEach(function(prof) { %>
                        <tr class="<%= !prof.activo ? 'admin-tabla__fila--inactiva' : '' %>" data-id="<%= prof.id %>"
                          data-nombre="<%= prof.nombre.toLowerCase() %>"
                          data-matricula="<%= prof.matricula.toLowerCase() %>"
                          data-servicio="<%= (prof.servicioNombre || prof.profesion || '').toLowerCase() %>"
                          data-valoracion="<%= prof.valoracion && prof.valoracion.valor ? prof.valoracion.valor : 0 %>">

                          <!-- Nombre + avatar -->
                          <td>
                            <div class="admin-tabla__celda-producto">
                              <div class="admin-tabla__avatar">
                                <%= prof.nombre.charAt(0).toUpperCase() %>
                              </div>
                              <div class="admin-tabla__producto-info">
                                <span class="admin-tabla__nombre">
                                  <%= prof.nombre %>
                                </span>
                                <% if (prof.trabajosCompletados> 0) { %>
                                  <span class="admin-tabla__descripcion-corta">
                                    <%= prof.trabajosCompletados %> trabajos
                                  </span>
                                  <% } %>
                              </div>
                            </div>
                          </td>

                          <!-- Matrícula -->
                          <td><code class="admin-tabla__codigo"><%= prof.matricula %></code></td>

                          <!-- Servicio -->
                          <td>
                            <span class="admin-tabla__badge-mini admin-tabla__badge-mini--info">
                              <%= prof.servicioNombre || prof.profesion || 'No especificado' %>
                            </span>
                          </td>

                          <!-- Estado del servicio -->
                          <td>
                            <span class="estado-servicio-badge estado-<%= prof.estadoServicio || 'pendiente' %>">
                              <% if (prof.estadoServicio==='aprobado' ) { %>
                                ✅ Aprobado
                                <% } else if (prof.estadoServicio==='pendiente' ) { %>
                                  ⏳ Pendiente
                                  <% } else if (prof.estadoServicio==='rechazado' ) { %>
                                    ❌ Rechazado
                                    <% } else { %>
                                      —
                                      <% } %>
                            </span>
                          </td>

                          <!-- Contacto -->
                          <td>
                            <div class="admin-tabla__contacto">
                              <div>
                                <%= prof.email %>
                              </div>
                              <% if (prof.telefono) { %>
                                <div class="admin-tabla__texto-suave">
                                  <%= prof.telefono %>
                                </div>
                                <% } %>
                            </div>
                          </td>

                          <!-- Valoración -->
                          <td class="admin-tabla__td-num">
                            <% if (prof.valoracion && prof.valoracion.valor> 0) { %>
                              <div class="admin-tabla__rating">
                                <span>★</span>
                                <span>
                                  <%= prof.valoracion.valor.toFixed(1) %>
                                </span>
                                <span class="admin-tabla__texto-suave">(<%= prof.valoracion.cantidad %>)</span>
                              </div>
                              <% } else { %>
                                <span class="admin-tabla__texto-suave">—</span>
                                <% } %>
                          </td>

                          <!-- Disponibilidad -->
                          <td>
                            <div class="admin-tabla__disponibilidad" title="Disponibilidad semanal">
                              <% const dias=['lunes', 'martes' , 'miercoles' , 'jueves' , 'viernes' ]; %>
                                <% const diasAbr=['L', 'M' , 'Mi' , 'J' , 'V' ]; %>
                                  <% for (let i=0; i < dias.length; i++) { %>
                                    <% const dia=dias[i]; %>
                                      <% const disponible=prof.disponibilidad && prof.disponibilidad[dia] &&
                                        (prof.disponibilidad[dia].manana || prof.disponibilidad[dia].tarde); %>
                                        <span
                                          class="admin-tabla__dia-dot <%= disponible ? 'admin-tabla__dia-dot--activo' : '' %>"
                                          title="<%= diasAbr[i] %> <%= disponible ? 'disponible' : 'no disponible' %>">
                                          <%= diasAbr[i] %>
                                        </span>
                                        <% } %>
                            </div>
                          </td>

                          <!-- Estado -->
                          <td>
                            <span class="admin-estado-dot admin-estado-dot--<%= prof.activo ? 'activo' : 'inactivo' %>">
                              <%= prof.activo ? 'Activo' : 'Inactivo' %>
                            </span>
                          </td>

                          <!-- Acciones -->
                          <td>
                            <div class="admin-tabla__acciones">
                              <a href="/admin/profesionales/<%= prof.id %>/editar" class="admin-tabla__btn-accion"
                                title="Editar">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                  stroke-width="2">
                                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                  <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                </svg>
                              </a>

                              <form action="/admin/profesionales/<%= prof.id %>/baja" method="POST"
                                class="form-toggle-estado" data-id="<%= prof.id %>" data-nombre="<%= prof.nombre %>"
                                data-activo="<%= prof.activo %>">
                                <input type="hidden" name="_method" value="DELETE">
                                <button type="button"
                                  class="admin-tabla__btn-accion <%= prof.activo ? 'admin-tabla__btn-accion--baja' : 'admin-tabla__btn-accion--alta' %> btn-toggle-estado"
                                  title="<%= prof.activo ? 'Dar de baja' : 'Reactivar' %>" data-id="<%= prof.id %>"
                                  data-nombre="<%= prof.nombre %>" data-activo="<%= prof.activo %>">
                                  <% if (prof.activo) { %>
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                      stroke-width="2">
                                      <circle cx="12" cy="12" r="10" />
                                      <line x1="4.93" y1="4.93" x2="19.07" y2="19.07" />
                                    </svg>
                                    <% } else { %>
                                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2">
                                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                                        <polyline points="22 4 12 14.01 9 11.01" />
                                      </svg>
                                      <% } %>
                                </button>
                              </form>
                            </div>
                          </td>
                        </tr>
                        <% }); %>
                    </tbody>
                  </table>
                </div>
                <% } %>
  </div>

  <!-- JavaScript externo -->
  <script src="/js/admin/professional-list.js"></script>