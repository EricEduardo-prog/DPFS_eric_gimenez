<%# Uso: - imagenUrl: string, URL de la imagen - altText: string, texto alternativo %>
<div class="imagen-preview" id="previewContainer_imagen">
    <% if (imagenUrl) { %>
        <img src="<%= imagenUrl %>" alt="<%= altText || 'Vista previa' %>" class="imagen-preview__img" id="previewImg_imagen">
    <% } else { %>
        <div class="imagen-preview__placeholder" id="previewPlaceholder_imagen">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                <polyline points="21 15 16 10 5 21"></polyline>
            </svg>
            <p>La preview aparece aquí</p>
        </div>
        <img src="" alt="<%= altText || 'Vista previa' %>" class="imagen-preview__img oculto" id="previewImg_imagen">
    <% } %>
</div>