<%# Uso: - name: string, nombre del input (ej: 'imagen') - id: string, id del input - value: string, URL inicial (opcional) - required: boolean %>
    <div class="campo-formulario">
        <label class="etiqueta-campo" for="<%= id %>">
            URL de imagen <span class="campo-requerido">*</span>
        </label>
        <div class="imagen-preview-bloque">
            <input type="url" id="<%= id %>" name="<%= name %>" class="entrada"
                placeholder="https://ejemplo.com/imagen-producto.jpg" value="<%= value || '' %>" <%=required
                ? 'required' : '' %>>
            <div class="imagen-preview" id="previewContainer_<%= id %>">
                <% if (value) { %>
                    <img src="<%= value %>" alt="Preview" class="imagen-preview__img" id="previewImg_<%= id %>">
                    <% } else { %>
                        <div class="imagen-preview__placeholder" id="previewPlaceholder_<%= id %>">
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                stroke-width="1.5">
                                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                                <circle cx="8.5" cy="8.5" r="1.5"></circle>
                                <polyline points="21 15 16 10 5 21"></polyline>
                            </svg>
                            <p>La preview aparece aquí</p>
                        </div>
                        <img src="" alt="Preview" class="imagen-preview__img oculto" id="previewImg_<%= id %>">
                        <% } %>
            </div>
        </div>
        <span class="mensaje-error" id="error-<%= name %>"></span>
    </div>